# OpenAI API
# Required. Used by the OpenAI Responses API client.
OPENAI_API_KEY=

# Browser Agent runtime
# Model used by the single Browser Agent.
AGENT_BROWSER_MODEL=gpt-4.1-mini

# Mobile platform: currently only "android" is implemented end-to-end.
AGENT_BROWSER_PLATFORM=android

# Optional. If unset, appium-cli will pick the first connected device.
AGENT_BROWSER_UDID=

# Appium server port. The server is expected to be already running at
# localhost:<port>. agent-browser does NOT install or start Appium for you.
AGENT_BROWSER_APPIUM_PORT=4723

# Maximum number of custom ReAct loop turns.
AGENT_BROWSER_MAX_TURNS=50

# Prompt memory caps.
AGENT_BROWSER_RECENT_STEPS=5
AGENT_BROWSER_MAX_OBSERVATION_CHARS=2500
AGENT_BROWSER_MAX_ACTION_RESULT_CHARS=500
AGENT_BROWSER_MAX_ERROR_CHARS=300
AGENT_BROWSER_WORKING_STATE_CHARS=1200

# Maximum same-tool retries before the agent must change strategy.
AGENT_BROWSER_MAX_RETRIES=2

# Per-step timeout for tool dispatch in seconds.
AGENT_BROWSER_STEP_TIMEOUT=60

# Fallback directory for screenshot artifacts when appium-cli does not return a path.
# Normal screenshots are saved by appium-cli under .appium-cli/<session-id>/.
AGENT_BROWSER_ARTIFACTS_DIR=.appium-cli/agent-browser/artifacts

# Where to persist episodic memory (JSONL).
AGENT_BROWSER_MEMORY_PATH=.agent-browser-memory.jsonl

# Logging level: DEBUG / INFO / WARNING / ERROR
AGENT_BROWSER_LOG_LEVEL=INFO

# Completion gate. The judge verifies explicit task completion using the final
# result plus the tool trace; it should not grade writing quality.
AGENT_BROWSER_VERIFY_WITH_LLM=true
AGENT_BROWSER_JUDGE_MODEL=gpt-4.1
